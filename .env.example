# APP
SERVICE_NAME=categorization-worker
ENV=stage
AWS_REGION=us-east-1

# DB
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=gigpf
DB_SSLMODE=disable

#SERVER
OTEL_COLLECTOR_ADDR=otel-collector:4317
METRICS_SERVER_PORT=:9100

# SQS
CATEGORIZATION_SQS_URL=http://localstack:4566/000000000000/gig-category-events
